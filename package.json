{
  "name": "opera-profile-merger",
  "version": "1.0.0",
  "description": "AI-driven profile merging system for Opera Cloud via OHIP",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "npm run build:frontend",
    "build:frontend": "npm --prefix frontend ci && npm --prefix frontend run build",
    "test": "jest",
    "lint": "eslint src/",
    "docker:build": "docker build -t opera-profile-merger .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run"
  },
  "keywords": [
    "opera",
    "ohip",
    "profile",
    "merge",
    "duplicate",
    "ai",
    "hotel"
  ],
  "author": "Hospitality Consulting Services",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "knex": "^3.0.1",
    "pg": "^8.11.3",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "uuid": "^9.0.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "eslint": "^8.54.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
